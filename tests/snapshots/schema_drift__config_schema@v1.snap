    },
    "gateway": {
      "description": "Gateway server configuration: host, port, pairing, rate limits (`[gateway]`).",
      "$ref": "#/$defs/GatewayConfig",
      "default": {
        "allow_public_bind": false,
        "host": "127.0.0.1",
        "idempotency_max_keys": 10000,
        "idempotency_ttl_secs": 300,
        "pair_rate_limit_per_minute": 10,
        "paired_tokens": [],
        "port": 3000,
        "rate_limit_max_keys": 10000,
        "request_timeout_secs": 300,
        "require_pairing": true,
        "trust_forwarded_headers": false,
        "webhook_rate_limit_per_minute": 60
      }
    },
    "gateway_agents": {
      "description": "Gateway agent configurations for multi-agent gateway routing.\nEach entry defines a co-equal agent hosted by the gateway, routed via `X-Agent-Id` header.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/GatewayAgentConfig"
      },
      "default": {}
    },
    "hardware": {
      "description": "Hardware configuration (wizard-driven physical world setup).",
      "$ref": "#/$defs/HardwareConfig",
      "default": {
        "baud_rate": 115200,
        "enabled": false,
        "probe_target": null,
        "serial_port": null,
        "transport": "None",
        "workspace_datasheets": false
      }
    },
    "heartbeat": {
      "description": "Heartbeat configuration for periodic health pings (`[heartbeat]`).",
      "$ref": "#/$defs/HeartbeatConfig",
      "default": {
        "enabled": false,
        "interval_minutes": 30
      }
    },
    "http_request": {
      "description": "HTTP request tool configuration (`[http_request]`).",
      "$ref": "#/$defs/HttpRequestConfig",
      "default": {
        "allowed_domains": [],
        "enabled": false,
        "max_response_size": 0,
        "timeout_secs": 0
      }
    },
    "identity": {
      "description": "Identity format configuration: OpenClaw or AIEOS (`[identity]`).",
      "$ref": "#/$defs/IdentityConfig",
      "default": {
        "aieos_inline": null,
        "aieos_path": null,
        "format": "openclaw"
      }
    },
    "mcp_servers": {
      "description": "MCP servers managed by the runtime (`[mcp_servers.<name>]`).",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/McpServerConfig"
      },
      "default": {}
    },
    "memory": {
      "description": "Memory backend configuration: sqlite, markdown, embeddings (`[memory]`).",
      "$ref": "#/$defs/MemoryConfig",
      "default": {
        "archive_after_days": 7,
        "auto_hydrate": true,
        "auto_save": true,
        "backend": "sqlite",
        "chunk_max_tokens": 512,
        "conversation_retention_days": 30,
        "embedding_cache_size": 10000,
        "embedding_dimensions": 1536,
        "embedding_model": "text-embedding-3-small",
        "embedding_provider": "none",
        "hygiene_enabled": true,
        "keyword_weight": 0.3,
        "min_relevance_score": 0.4,
        "purge_after_days": 30,
        "response_cache_enabled": false,
        "response_cache_max_entries": 5000,
        "response_cache_ttl_minutes": 60,
        "snapshot_enabled": false,
        "snapshot_on_hygiene": false,
        "sqlite_open_timeout_secs": null,
        "vector_weight": 0.7
      }
    },
    "model_routes": {
      "description": "Model routing rules — route `hint:<name>` to specific provider+model combos.",
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ModelRouteConfig"
      }
    },
    "multimodal": {
      "description": "Multimodal (image) handling configuration (`[multimodal]`).",
      "$ref": "#/$defs/MultimodalConfig",
      "default": {
        "allow_remote_fetch": false,
        "max_image_size_mb": 5,
        "max_images": 4
      }
    },
    "observability": {
      "description": "Observability backend configuration (`[observability]`).",
      "$ref": "#/$defs/ObservabilityConfig",
      "default": {
        "backend": "none",
