---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Top-level RantaiClaw configuration, loaded from `config.toml`.\n\nResolution order: `RANTAICLAW_WORKSPACE` env → `active_workspace.toml` marker → `~/.rantaiclaw/config.toml`.",
  "type": "object",
  "properties": {
    "agent": {
      "description": "Agent orchestration settings (`[agent]`).",
      "$ref": "#/$defs/AgentConfig",
      "default": {
        "compact_context": false,
        "max_history_messages": 50,
        "max_tool_iterations": 10,
        "parallel_tools": false,
        "tool_dispatcher": "auto"
      }
    },
    "agents": {
      "description": "Delegate agent configurations for multi-agent workflows.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/DelegateAgentConfig"
      },
      "default": {}
    },
    "api_key": {
      "description": "API key for the selected provider. Overridden by `RANTAICLAW_API_KEY` or `API_KEY` env vars.",
      "type": [
        "string",
        "null"
      ]
    },
    "api_url": {
      "description": "Base URL override for provider API (e.g. \"http://10.0.0.1:11434\" for remote Ollama)",
      "type": [
        "string",
        "null"
      ]
    },
    "autonomy": {
      "description": "Autonomy and security policy configuration (`[autonomy]`).",
      "$ref": "#/$defs/AutonomyConfig",
      "default": {
        "allowed_commands": [
          "git",
          "npm",
          "cargo",
          "ls",
          "cat",
          "grep",
          "find",
          "echo",
          "pwd",
          "wc",
          "head",
          "tail"
        ],
        "always_ask": [],
        "auto_approve": [
          "file_read",
          "memory_recall"
        ],
        "block_high_risk_commands": true,
        "forbidden_paths": [
          "/etc",
          "/root",
          "/home",
          "/usr",
          "/bin",
          "/sbin",
          "/lib",
          "/opt",
          "/boot",
          "/dev",
          "/proc",
          "/sys",
          "/var",
          "/tmp",
          "~/.ssh",
          "~/.gnupg",
          "~/.aws",
          "~/.config"
        ],
        "level": "supervised",
        "max_actions_per_hour": 20,
        "max_cost_per_day_cents": 500,
        "require_approval_for_medium_risk": true,
        "workspace_only": true
      }
    },
    "browser": {
      "description": "Browser automation configuration (`[browser]`).",
      "$ref": "#/$defs/BrowserConfig",
      "default": {
        "allowed_domains": [],
        "backend": "agent_browser",
        "computer_use": {
          "allow_remote_endpoint": false,
          "api_key": null,
          "endpoint": "http://127.0.0.1:8787/v1/actions",
          "max_coordinate_x": null,
          "max_coordinate_y": null,
          "timeout_ms": 15000,
          "window_allowlist": []
        },
        "enabled": false,
        "native_chrome_path": null,
        "native_headless": true,
        "native_webdriver_url": "http://127.0.0.1:9515",
        "session_name": null
      }
    },
    "channels_config": {
      "description": "Channel configurations: Telegram, Discord, Slack, etc. (`[channels_config]`).",
      "$ref": "#/$defs/ChannelsConfig",
      "default": {
        "cli": true,
        "dingtalk": null,
        "discord": null,
        "email": null,
        "imessage": null,
        "irc": null,
        "lark": null,
